{
  "name": "contentful.php",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "PHP_VERSION": "${localEnv:PHP_VERSION:8.1}"
    }
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode",
  "postCreateCommand": ".devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug"
      ]
    }
  }
}
